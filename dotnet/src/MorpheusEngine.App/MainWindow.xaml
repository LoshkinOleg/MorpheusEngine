<Window x:Class="MorpheusEngine.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MorpheusEngine"
        Height="720"
        Width="1100"
        MinHeight="520"
        MinWidth="820">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="MorpheusEngine"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="Game chat plus debug tooling"
                           Margin="0,2,0,0"
                           Foreground="#AEB5C4" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Game project:"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center"
                           Foreground="#AEB5C4" />
                <TextBox x:Name="GameProjectIdTextBox"
                         Width="160"
                         Height="30"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         FontSize="13"
                         Background="#171C26"
                         Foreground="White"
                         BorderBrush="#324055"
                         BorderThickness="1"
                         Text="sandcrawler" />
                <Button x:Name="StartButton"
                        Width="92"
                        Height="30"
                        Content="Start Engine"
                        Click="StartButton_Click" />
                <Ellipse x:Name="EngineStatusEllipse"
                         Width="12"
                         Height="12"
                         Margin="12,0"
                         VerticalAlignment="Center"
                         Fill="#5A5F6A"
                         ToolTip="Engine stopped" />
                <Button x:Name="StopButton"
                        Width="92"
                        Height="30"
                        Content="Stop Engine"
                        Click="StopButton_Click" />
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2">
            <TabItem Header="Game">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="12"
                            Background="#171C26"
                            BorderBrush="#2D3748"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Game"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock x:Name="GameTurnHeaderTextBlock"
                                       Margin="0,4,0,0"
                                       Foreground="#B7C4D9"
                                       Text="Current turn: 1" />
                            <TextBlock x:Name="GameStatusTextBlock"
                                       Margin="0,8,0,0"
                                       Foreground="#B0C4DE"
                                       Text="" />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="GameChatInteractionRoot"
                          Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="10"
                                Background="#0F131B"
                                BorderBrush="#2B3444"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ScrollViewer x:Name="GameMessagesScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Padding="0,0,0,12">
                                <ItemsControl x:Name="GameMessagesItemsControl"
                                              Background="Transparent">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12"
                                                        HorizontalAlignment="{Binding BubbleAlignment}">
                                                <TextBlock Text="{Binding SpeakerHeading}"
                                                           Margin="4,0,4,4"
                                                           Foreground="#93A4BC"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                                <Border MaxWidth="560"
                                                        Padding="12,10"
                                                        Background="{Binding BubbleBackground}"
                                                        BorderBrush="{Binding BubbleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="14">
                                                    <TextBox Text="{Binding Text, Mode=OneWay}"
                                                             Foreground="{Binding BubbleForeground}"
                                                             CaretBrush="{Binding BubbleForeground}"
                                                             FontSize="13"
                                                             TextWrapping="Wrap"
                                                             AcceptsReturn="True"
                                                             IsReadOnly="True"
                                                             IsTabStop="False"
                                                             Focusable="True"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Padding="0" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="GameInputTextBox"
                                     Grid.Column="0"
                                     Height="42"
                                     VerticalContentAlignment="Center"
                                     Padding="12,0"
                                     FontSize="14"
                                     Background="#171C26"
                                     Foreground="White"
                                     BorderBrush="#324055"
                                     BorderThickness="1"
                                     KeyDown="GameInputTextBox_KeyDown" />

                            <Button x:Name="GameSendButton"
                                    Grid.Column="2"
                                    Width="92"
                                    Height="42"
                                    Content="Send"
                                    Click="GameSendButton_Click" />
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Debug">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="220" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="3*" MinHeight="180" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderThickness="1"
                            BorderBrush="#4A4A4A"
                            CornerRadius="4"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Port:" />
                            <ComboBox x:Name="PortComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Height="28"
                                      SelectionChanged="PortComboBox_SelectionChanged" />

                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="Endpoint:" />
                            <TextBox x:Name="EndpointTextBox"
                                     Grid.Row="0"
                                     Grid.Column="4"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     Text="/info"
                                     TextChanged="EndpointTextBox_TextChanged" />

                            <Button x:Name="SendHttpButton"
                                    Grid.Row="0"
                                    Grid.Column="6"
                                    Width="80"
                                    Height="28"
                                    Content="Send"
                                    Click="SendHttpButton_Click" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Preset:" />
                            <ComboBox x:Name="EndpointPresetComboBox"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="4"
                                      Height="28"
                                      SelectionChanged="EndpointPresetComboBox_SelectionChanged" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Custom Port:" />
                            <TextBox x:Name="CustomPortTextBox"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     TextChanged="CustomPortTextBox_TextChanged" />

                            <TextBox x:Name="HttpRequestBodyTextBox"
                                     Grid.Row="6"
                                     Grid.ColumnSpan="7"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Background="#101010"
                                     Foreground="#DDDDDD"
                                     Padding="8" />

                            <TextBox x:Name="HttpResponsePane"
                                     Grid.Row="8"
                                     Grid.ColumnSpan="7"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Background="#151515"
                                     Foreground="#DCDCDC"
                                     Padding="8" />
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Height="6"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="#3F3F3F" />

                    <TabControl Grid.Row="2">
                        <TabItem Header="Console">
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0"
                                        Width="72"
                                        Height="26"
                                        HorizontalAlignment="Right"
                                        Content="Copy"
                                        Click="CopyConsoleToClipboardButton_Click" />
                                <Border Grid.Row="2"
                                        BorderThickness="1"
                                        BorderBrush="#4A4A4A"
                                        CornerRadius="4">
                                    <TextBox x:Name="ConsolePane"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap"
                                             Background="#111111"
                                             Foreground="#DDDDDD"
                                             Padding="8" />
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Qwen Monitor">
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Text="Qwen Monitor" />

                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button Width="72"
                                            Height="26"
                                            Content="Copy"
                                            Click="CopyQwenMonitorToClipboardButton_Click" />
                                    <Button Width="72"
                                            Height="26"
                                            Margin="8,0,0,0"
                                            Content="Clear"
                                            Click="ClearQwenMonitorButton_Click" />
                                </StackPanel>

                                <Border Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        BorderThickness="1"
                                        BorderBrush="#4A4A4A"
                                        CornerRadius="4">
                                    <TextBox x:Name="QwenMonitorPane"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap"
                                             Background="#131722"
                                             Foreground="#D6E3FF"
                                             Padding="8" />
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
