<Window x:Class="MorpheusEngine.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MorpheusEngine"
        Height="600"
        Width="1000"
        MinHeight="400"
        MinWidth="700">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="220" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="MorpheusEngine Console"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <Button x:Name="StartButton"
                    Grid.Column="1"
                    Width="92"
                    Height="30"
                    Content="Start Engine"
                    Click="StartButton_Click" />

            <Button x:Name="StopButton"
                    Grid.Column="3"
                    Width="92"
                    Height="30"
                    Content="Stop Engine"
                    Click="StopButton_Click" />
        </Grid>

        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#4A4A4A" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Port:" />
                <TextBox x:Name="PortTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Height="28"
                         VerticalContentAlignment="Center"
                         Text="8790" />

                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Text="Endpoint:" />
                <TextBox x:Name="EndpointTextBox"
                         Grid.Row="0"
                         Grid.Column="4"
                         Height="28"
                         VerticalContentAlignment="Center"
                         Text="/info" />

                <Button x:Name="SendHttpButton"
                        Grid.Row="0"
                        Grid.Column="6"
                        Width="80"
                        Height="28"
                        Content="Send"
                        Click="SendHttpButton_Click" />

                <TextBox x:Name="HttpResponsePane"
                         Grid.Row="2"
                         Grid.ColumnSpan="7"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Background="#151515"
                         Foreground="#DCDCDC"
                         Padding="8" />
            </Grid>
        </Border>

        <Border Grid.Row="4" BorderThickness="1" BorderBrush="#4A4A4A" CornerRadius="4">
            <TextBox x:Name="ConsolePane"
                     FontFamily="Consolas"
                     FontSize="13"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     Background="#111111"
                     Foreground="#DDDDDD"
                     Padding="8"/>
        </Border>
    </Grid>
</Window>
