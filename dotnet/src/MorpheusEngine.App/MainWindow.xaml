<Window x:Class="MorpheusEngine.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MorpheusEngine"
        Height="720"
        Width="1100"
        MinHeight="520"
        MinWidth="820">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="MorpheusEngine"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="Game chat plus debug tooling"
                           Margin="0,2,0,0"
                           Foreground="#AEB5C4" />
            </StackPanel>

            <Button x:Name="StartButton"
                    Grid.Column="1"
                    Width="92"
                    Height="30"
                    Content="Start Engine"
                    Click="StartButton_Click" />

            <Button x:Name="StopButton"
                    Grid.Column="3"
                    Width="92"
                    Height="30"
                    Content="Stop Engine"
                    Click="StopButton_Click" />
        </Grid>

        <TabControl Grid.Row="2">
            <TabItem Header="Game">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="12"
                            Background="#171C26"
                            BorderBrush="#2D3748"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Game"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#B7C4D9"
                                       Text="Submit player input here. For now, the engine reply is the intent returned from router /turn." />
                            <TextBlock x:Name="GameStatusTextBlock"
                                       Margin="0,8,0,0"
                                       Foreground="#B0C4DE"
                                       Text="Ready." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Padding="10"
                            Background="#0F131B"
                            BorderBrush="#2B3444"
                            BorderThickness="1"
                            CornerRadius="10">
                        <ListBox x:Name="GameMessagesListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Focusable" Value="False" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="{Binding BubbleAlignment}">
                                        <TextBlock Text="{Binding SpeakerLabel}"
                                                   Margin="4,0,4,4"
                                                   Foreground="#93A4BC"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                        <Border MaxWidth="560"
                                                Padding="12,10"
                                                Background="{Binding BubbleBackground}"
                                                BorderBrush="{Binding BubbleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <TextBlock Text="{Binding Text}"
                                                       Foreground="{Binding BubbleForeground}"
                                                       TextWrapping="Wrap"
                                                       FontSize="13" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="GameInputTextBox"
                                 Grid.Column="0"
                                 Height="42"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 FontSize="14"
                                 Background="#171C26"
                                 Foreground="White"
                                 BorderBrush="#324055"
                                 BorderThickness="1"
                                 KeyDown="GameInputTextBox_KeyDown" />

                        <Button x:Name="GameSendButton"
                                Grid.Column="2"
                                Width="92"
                                Height="42"
                                Content="Send"
                                Click="GameSendButton_Click" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Debug">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="220" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="3*" MinHeight="180" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderThickness="1"
                            BorderBrush="#4A4A4A"
                            CornerRadius="4"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Port:" />
                            <ComboBox x:Name="PortComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Height="28"
                                      SelectionChanged="PortComboBox_SelectionChanged" />

                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="Endpoint:" />
                            <TextBox x:Name="EndpointTextBox"
                                     Grid.Row="0"
                                     Grid.Column="4"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     Text="/info"
                                     TextChanged="EndpointTextBox_TextChanged" />

                            <Button x:Name="SendHttpButton"
                                    Grid.Row="0"
                                    Grid.Column="6"
                                    Width="80"
                                    Height="28"
                                    Content="Send"
                                    Click="SendHttpButton_Click" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Preset:" />
                            <ComboBox x:Name="EndpointPresetComboBox"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="4"
                                      Height="28"
                                      SelectionChanged="EndpointPresetComboBox_SelectionChanged" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Custom Port:" />
                            <TextBox x:Name="CustomPortTextBox"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     TextChanged="CustomPortTextBox_TextChanged" />

                            <TextBox x:Name="HttpRequestBodyTextBox"
                                     Grid.Row="6"
                                     Grid.ColumnSpan="7"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Background="#101010"
                                     Foreground="#DDDDDD"
                                     Padding="8" />

                            <TextBox x:Name="HttpResponsePane"
                                     Grid.Row="8"
                                     Grid.ColumnSpan="7"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     Background="#151515"
                                     Foreground="#DCDCDC"
                                     Padding="8" />
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Height="6"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="#3F3F3F" />

                    <TabControl Grid.Row="2">
                        <TabItem Header="Console">
                            <Border Margin="6"
                                    BorderThickness="1"
                                    BorderBrush="#4A4A4A"
                                    CornerRadius="4">
                                <TextBox x:Name="ConsolePane"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"
                                         Background="#111111"
                                         Foreground="#DDDDDD"
                                         Padding="8" />
                            </Border>
                        </TabItem>
                        <TabItem Header="Qwen Monitor">
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Text="Qwen Monitor" />

                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="72"
                                        Height="26"
                                        Content="Clear"
                                        Click="ClearQwenMonitorButton_Click" />

                                <Border Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        BorderThickness="1"
                                        BorderBrush="#4A4A4A"
                                        CornerRadius="4">
                                    <TextBox x:Name="QwenMonitorPane"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap"
                                             Background="#131722"
                                             Foreground="#D6E3FF"
                                             Padding="8" />
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
