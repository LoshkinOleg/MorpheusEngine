{
  "module_aliases": {
    "generic_llm_provider": "llm_provider_qwen"
  },
  "ports": {
    "router": 8790,
    "llm_provider_qwen": 8791,
    "intent_extractor": 8792,
    "session_store": 8793
  },
  "modules": [
    {
      "port_key": "router",
      "display_name": "RouterModule",
      "required": true,
      "launch": {
        "artifact": "dotnet/src/MorpheusEngine.RouterModule/bin/Debug/net9.0/MorpheusEngine.RouterModule.exe",
        "dev_project": "dotnet/src/MorpheusEngine.RouterModule/MorpheusEngine.RouterModule.csproj"
      },
      "endpoints": [
        {
          "path": "/info",
          "description": "Module metadata",
          "method": "GET"
        },
        {
          "path": "/health",
          "description": "Health check",
          "method": "GET"
        },
        {
          "path": "/turn",
          "description": "Submit player turn",
          "method": "POST",
          "request_contract": "turn_request"
        },
        {
          "path": "/run/start",
          "description": "Initialize per-run session database (forwards to session_store)",
          "method": "POST",
          "request_contract": "run_start_request"
        }
      ]
    },
    {
      "port_key": "llm_provider_qwen",
      "display_name": "LlmProvider_qwen",
      "required": true,
      "ollama_port": 11434,
      "launch": {
        "artifact": "dotnet/src/MorpheusEngine.LlmProvider_qwen/bin/Debug/net9.0/MorpheusEngine.LlmProvider_qwen.exe",
        "dev_project": "dotnet/src/MorpheusEngine.LlmProvider_qwen/MorpheusEngine.LlmProvider_qwen.csproj"
      },
      "endpoints": [
        {
          "path": "/info",
          "description": "Module metadata",
          "method": "GET"
        },
        {
          "path": "/health",
          "description": "Health check",
          "method": "GET"
        },
        {
          "path": "/generate",
          "description": "LLM generate",
          "method": "POST",
          "request_contract": "qwen_generate_request"
        }
      ]
    },
    {
      "port_key": "intent_extractor",
      "display_name": "IntentExtractor",
      "required": true,
      "default_llm_model": "qwen2.5:7b-instruct",
      "launch": {
        "artifact": "dotnet/src/MorpheusEngine.IntentExtractor/bin/Debug/net9.0/MorpheusEngine.IntentExtractor.exe",
        "dev_project": "dotnet/src/MorpheusEngine.IntentExtractor/MorpheusEngine.IntentExtractor.csproj"
      },
      "endpoints": [
        {
          "path": "/info",
          "description": "Module metadata",
          "method": "GET"
        },
        {
          "path": "/health",
          "description": "Health check",
          "method": "GET"
        },
        {
          "path": "/intent",
          "description": "Extract player intent",
          "method": "POST",
          "request_contract": "intent_request"
        }
      ]
    },
    {
      "port_key": "session_store",
      "display_name": "SessionStore",
      "required": true,
      "launch": {
        "artifact": "dotnet/src/MorpheusEngine.SessionStoreModule/bin/Debug/net9.0/MorpheusEngine.SessionStoreModule.exe",
        "dev_project": "dotnet/src/MorpheusEngine.SessionStoreModule/MorpheusEngine.SessionStoreModule.csproj"
      },
      "endpoints": [
        {
          "path": "/info",
          "description": "Module metadata",
          "method": "GET"
        },
        {
          "path": "/health",
          "description": "Health check",
          "method": "GET"
        },
        {
          "path": "/run/start",
          "description": "Create run folder, world_state.db, schema, turn-0 snapshot",
          "method": "POST",
          "request_contract": "run_start_request"
        },
        {
          "path": "/turn/validate",
          "description": "Validate turn sequencing against snapshots",
          "method": "POST",
          "request_contract": "session_turn_validate_request"
        },
        {
          "path": "/turn/persist",
          "description": "Persist events + snapshot for a validated turn",
          "method": "POST",
          "request_contract": "session_turn_persist_request"
        }
      ]
    }
  ]
}
